# ── Required ────────────────────────────────────────────────────────────────
# Supabase project (Dashboard -> Project Settings -> API).
# Without these the app silently talks to a placeholder project: sign-in never
# creates a session and every query returns empty. lib/supabase.js throws in
# development if they're absent.
# Fastest way to get a working .env.local:  vercel env pull .env.local
NEXT_PUBLIC_SUPABASE_URL=https://your_project_ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Server-only. Used by admin/cron routes that bypass row-level security.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Feature keys ────────────────────────────────────────────────────────────
# Google Places API key (from Google Cloud Console)
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Gmail OAuth Client ID (from Google Cloud Console -> Credentials -> OAuth 2.0 Client ID)
NEXT_PUBLIC_GMAIL_CLIENT_ID=your_gmail_oauth_client_id_here

# Gmail OAuth Client Secret (same OAuth 2.0 credential as the Client ID above).
# Server-only — used to exchange auth codes / refresh tokens so Gmail stays connected.
GMAIL_CLIENT_SECRET=your_gmail_oauth_client_secret_here
